{% extends 'base.html.twig' %}

{% block title %}{{ title }} | CERCLE DUCLOS{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-32 animate-in fade-in duration-500 text-center flex flex-col items-center justify-center">
