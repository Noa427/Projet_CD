{% extends 'base.html.twig' %}

{% block title %}CERCLE DUCLOS | Indépendance & Reconquête{% endblock %}

{% block body %}
<div class="animate-in fade-in duration-500">
    <!-- HERO SECTION -->
    <section class="relative py-32 px-4 sm:px-6 lg:px-8 border-b border-slate-200 dark:border-zinc-800 bg-slate-50 dark:bg-black overflow-hidden transition-colors duration-500 mt-0">
        <!-- Background Grid Pattern -->
        <div class="absolute inset-0 bg-[linear-gradient(rgba(0,0,0,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(0,0,0,0.03)_1px,transparent_1px)] bg-[size:32px_32px] pointer-events-none dark:opacity-0 transition-opacity duration-500"></div>
        <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:32px_32px] pointer-events-none opacity-0 dark:opacity-100 transition-opacity duration-500"></div>
        
        <div class="max-w-4xl mx-auto text-center relative z-10">
            <div class="inline-flex items-center gap-2 px-3 py-1 mb-12 border border-blue-200 dark:border-blue-900/50 bg-white dark:bg-blue-950/20 text-blue-900 dark:text-blue-400 font-mono text-xs uppercase tracking-widest shadow-sm dark:shadow-none">
                Indépendance & Reconquête
            </div>
            <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-slate-900 dark:text-white tracking-tighter uppercase mb-8 drop-shadow-[0_0_15px_rgba(30,58,138,0.15)] dark:drop-shadow-[0_0_15px_rgba(59,130,246,0.2)] pt-4">
                Indépendance Nationale <br /> <span class="text-blue-900 dark:text-blue-500">Reconquête Sociale.</span>
            </h2>
            <p class="text-lg text-slate-600 dark:text-zinc-400 mb-10 font-mono max-w-2xl mx-auto leading-relaxed">
                Groupe de réflexion communiste et souverainiste.<br/>
                Objectif : Sortie de l'UE et défense du monde du travail.
            </p>
            <div class="flex flex-col sm:flex-row justify-center items-center gap-6">
                <a href="#" class="bg-blue-900 hover:bg-blue-800 dark:bg-blue-600 dark:hover:bg-blue-500 text-white dark:text-black px-8 py-3 text-sm font-black uppercase tracking-widest transition-all relative overflow-hidden group shadow-md dark:shadow-none">
                    <span class="relative z-10 flex items-center gap-2">S'engager <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span>
                </a>
                <a href="{{ path('app_analyses') }}" class="border border-slate-300 hover:border-blue-900 dark:border-zinc-700 dark:hover:border-blue-500 text-slate-600 hover:text-blue-900 dark:text-zinc-300 dark:hover:text-blue-400 px-8 py-3 text-sm font-bold uppercase tracking-widest transition-colors bg-white/50 dark:bg-zinc-950/50">
                    Accéder aux dossiers
                </a>
            </div>
        </div>
    </section>

    <!-- EN VEDETTE -->
    <section class="py-20 px-4 sm:px-6 lg:px-8 bg-white dark:bg-zinc-950 relative transition-colors duration-500">
        <div class="max-w-7xl mx-auto">
            <div class="flex items-center gap-4 mb-10 border-b border-slate-200 dark:border-zinc-800 pb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-900 dark:text-blue-500"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
                <h3 class="text-xl font-mono font-bold text-slate-900 dark:text-white uppercase tracking-widest">
                    À la une
                </h3>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Card 1 -->
                <div class="relative bg-white dark:bg-black border border-slate-200 dark:border-zinc-800 hover:border-blue-900/50 dark:hover:border-blue-500/50 transition-colors duration-300 p-6 group cursor-pointer">
                    <div class="absolute top-0 left-0 w-2 h-2 border-t border-l border-blue-900 dark:border-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <div class="absolute top-0 right-0 w-2 h-2 border-t border-r border-blue-900 dark:border-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <div class="absolute bottom-0 left-0 w-2 h-2 border-b border-l border-blue-900 dark:border-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <div class="absolute bottom-0 right-0 w-2 h-2 border-b border-r border-blue-900 dark:border-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    
                    <div class="flex items-center justify-between mb-6 font-mono text-xs uppercase tracking-widest border-b border-slate-100 dark:border-zinc-800 pb-2">
                        <span class="text-blue-900 dark:text-blue-500 flex items-center gap-2 font-bold">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                            Analyse
                        </span>
                        <span class="text-slate-400 dark:text-zinc-500">12 Février 2026</span>
                    </div>
                    <h4 class="text-2xl font-black text-slate-900 dark:text-white mb-4 uppercase tracking-tight group-hover:text-blue-900 dark:group-hover:text-blue-400 transition-colors">
                        La nation, cadre indépassable de la lutte des classes
                    </h4>
                    <p class="text-slate-600 dark:text-zinc-400 font-mono text-sm leading-relaxed mb-6">
                        Pourquoi toute volonté de transformation sociale se heurte invariablement au mur des traités européens. Le retour à la souveraineté nationale n'est pas une option, c'est un prérequis.
                    </p>
                    <div class="text-xs font-mono text-slate-500 dark:text-zinc-600 uppercase">
                        Par <span class="text-slate-800 dark:text-zinc-300 font-semibold">Comité de rédaction</span>
                    </div>
                </div>

                <!-- Card 2 -->
                <div class="relative bg-white dark:bg-black border border-slate-200 dark:border-zinc-800 hover:border-blue-900/50 dark:hover:border-blue-500/50 transition-colors duration-300 p-6 group cursor-pointer">
                    <div class="absolute top-0 left-0 w-2 h-2 border-t border-l border-blue-900 dark:border-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <div class="absolute top-0 right-0 w-2 h-2 border-t border-r border-blue-900 dark:border-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <div class="absolute bottom-0 left-0 w-2 h-2 border-b border-l border-blue-900 dark:border-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <div class="absolute bottom-0 right-0 w-2 h-2 border-b border-r border-blue-900 dark:border-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    
                    <div class="flex items-center justify-between mb-6 font-mono text-xs uppercase tracking-widest border-b border-slate-100 dark:border-zinc-800 pb-2">
                        <span class="text-blue-900 dark:text-blue-500 flex items-center gap-2 font-bold">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            Entretien
                        </span>
                        <span class="text-slate-400 dark:text-zinc-500">05 Février 2026</span>
                    </div>
                    <h4 class="text-2xl font-black text-slate-900 dark:text-white mb-4 uppercase tracking-tight group-hover:text-blue-900 dark:group-hover:text-blue-400 transition-colors">
                        Wokisme et abandon de la classe ouvrière
                    </h4>
                    <p class="text-slate-600 dark:text-zinc-400 font-mono text-sm leading-relaxed mb-6">
                        Intervention de François Weill sur la dérive sociétale des partis dits "de gauche" et la nécessité de renouer avec le marxisme originel.
                    </p>
                    <div class="text-xs font-mono text-slate-500 dark:text-zinc-600 uppercase">
                        Par <span class="text-slate-800 dark:text-zinc-300 font-semibold">François Weill</span>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
{% endblock %}
