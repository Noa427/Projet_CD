{% extends 'base.html.twig' %}

{% block title %}Connexion - CERCLE DUCLOS{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-4 py-20 animate-in fade-in duration-500">
    <div class="bg-white dark:bg-zinc-950 border border-slate-200 dark:border-zinc-900 p-8 shadow-xl">
        <div class="mb-8 text-center">
            <h2 class="text-2xl font-black text-slate-900 dark:text-white uppercase tracking-tighter">Accès Sécurisé</h2>
            <div class="h-1 w-12 bg-blue-900 dark:bg-blue-600 mx-auto mt-2"></div>
        </div>

        <form method="post">
            {% if error %}
                <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-900/50 text-red-800 dark:text-red-400 p-4 mb-6 text-sm font-mono">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <div class="mb-6">
                <label for="inputUsername" class="block text-xs font-mono font-bold text-slate-500 dark:text-zinc-500 uppercase mb-2">Nom d'utilisateur</label>
                <input type="text" value="{{ last_username }}" name="_username" id="inputUsername" class="w-full bg-slate-50 dark:bg-zinc-900 border border-slate-200 dark:border-zinc-800 px-4 py-3 text-slate-900 dark:text-white focus:outline-none focus:border-blue-900 dark:focus:border-blue-500 transition-colors" autocomplete="username" required autofocus>
            </div>

            <div class="mb-8">
                <label for="inputPassword" class="block text-xs font-mono font-bold text-slate-500 dark:text-zinc-500 uppercase mb-2">Mot de passe</label>
                <input type="password" name="_password" id="inputPassword" class="w-full bg-slate-50 dark:bg-zinc-900 border border-slate-200 dark:border-zinc-800 px-4 py-3 text-slate-900 dark:text-white focus:outline-none focus:border-blue-900 dark:focus:border-blue-500 transition-colors" autocomplete="current-password" required>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="w-full bg-blue-900 hover:bg-blue-800 dark:bg-blue-600 dark:hover:bg-blue-500 text-white dark:text-black font-black uppercase tracking-widest py-4 transition-all shadow-md">
                Se connecter
            </button>
        </form>
    </div>
</div>
{% endblock %}
